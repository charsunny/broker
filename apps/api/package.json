{
  "name": "@insurance/api",
  "version": "0.1.0",
  "private": true,
  "description": "NestJS 后端: 鉴权 / LangGraph 编排 / 佣金引擎 / Server-Driven UI",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:int": "vitest run --config vitest.int.config.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/config/db/migrate.ts",
    "db:seed": "tsx src/config/db/seed.ts"
  },
  "dependencies": {
    "@insurance/contracts": "workspace:*",
    "@langchain/langgraph": "^0.2.39",
    "@langchain/core": "^0.3.40",
    "@nestjs/common": "^10.4.4",
    "@nestjs/core": "^10.4.4",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.4",
    "drizzle-orm": "^0.36.4",
    "exceljs": "^4.4.0",
    "ioredis": "^5.4.1",
    "isolated-vm": "^5.0.1",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.4",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.7.4",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  }
}
