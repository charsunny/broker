# ===== 后端服务 (apps/api) =====
NODE_ENV=development
PORT=3000

# ----- PostgreSQL (配置表 + LangGraph checkpoint) -----
DATABASE_URL=postgresql://insurance:insurance@localhost:5432/insurance

# ----- Redis (语义缓存 / 规则字典预热 / 限流排队) -----
REDIS_URL=redis://localhost:6379

# ----- 鉴权 (Phase 1: 手机号白名单 + JWT) -----
JWT_SECRET=change-me-in-prod
JWT_EXPIRES_IN=12h
# 逗号分隔的允许登录手机号白名单 (Phase 1 简化方案)
BROKER_PHONE_WHITELIST=13800000000,13900000000

# ----- LLM 适配层 (国内模型, OpenAI 兼容端点) -----
# 支持 dashscope(通义千问) / deepseek / moonshot, 通过 baseURL 切换
LLM_PROVIDER=deepseek
LLM_API_KEY=sk-xxxxxxxx
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
# 温度建议 0, 抽取/反问要确定性
LLM_TEMPERATURE=0

# ----- 沙箱 (isolated-vm) -----
SANDBOX_TIMEOUT_MS=3000
SANDBOX_MEMORY_LIMIT_MB=128
SANDBOX_MAX_RETRIES=3

# ===== 前端 (apps/web) =====
TARO_APP_API_BASE=http://localhost:3000/api/v1
